# ── Environment / secrets ─────────────────────────────────
.env
.env.local
.env.*.local
*.pem

# ── Node / Next.js ────────────────────────────────────────
node_modules/
.next/
out/
build/
dist/
*.tsbuildinfo
next-env.d.ts
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.vercel
/coverage

# ── Python (scrapers) ─────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.python-version

# ── Data ──────────────────────────────────────────────────
# Raw scraper outputs are reproducible; don't commit massive CSVs
data/raw/*.csv
data/raw/*.json
data/cleaned/*.csv
data/verified/*.csv
data/enriched/*.csv
# Keep folder structure with .gitkeep
!data/**/.gitkeep

# Final import-ready CSVs CAN be committed (small, reviewed)
# data/final/  ← commit these intentionally

# ── Scraper binaries ──────────────────────────────────────
scrapers/google-maps-scraper/google-maps-scraper
scrapers/google-maps-scraper/*.exe

# ── IDE / OS ──────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# ── Logs ──────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Supabase local ────────────────────────────────────────
supabase/.branches/
supabase/.temp/

# ── SEO audit skill + reports (local tooling, not app code) ─
.agents/
audit-report*.xml
seomator.toml
.seomator/
