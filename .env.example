# ADUVerified — environment variables template
# Copy this file to .env and fill in real values.
# .env is gitignored. .env.example is committed.

# ── Site config ───────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://aduverified.com
NEXT_PUBLIC_SITE_NAME=ADUVerified

# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Resend (lead notification emails) ─────────────────────
RESEND_API_KEY=
LEAD_NOTIFY_FROM=leads@aduverified.com
ADMIN_EMAIL=ckruegs71@gmail.com

# ── Anthropic (Claude API for enrichment scripts) ─────────
ANTHROPIC_API_KEY=

# ── Google Gemini (vision / image curation) ───────────────
GEMINI_API_KEY=

# ── Outscraper (paid scrape fallback if gosom gets IP-blocked) ─
OUTSCRAPER_API_KEY=

# ── Free scraping (gosom/google-maps-scraper) ─────────────
SCRAPER_PROXY_URL=
SCRAPER_USER_AGENT=

# ── Stripe (Phase 2: paid leads / featured listings) ──────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Analytics ─────────────────────────────────────────────
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=aduverified.com
POSTHOG_API_KEY=
